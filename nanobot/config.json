{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "coder-model",
      "provider": "custom",
      "maxTokens": 8192,
      "contextWindowTokens": 65536,
      "temperature": 0.1,
      "maxToolIterations": 40,
      "reasoningEffort": null,
      "timezone": "UTC"
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
    "sendMaxRetries": 3,
    "webchat": {
      "enabled": true,
      "allow_from": ["*"]
    }
  },
  "providers": {
    "custom": {
      "apiKey": "",
      "apiBase": "",
      "extraHeaders": null
    }
  },
  "tools": {
    "web": {
      "proxy": null,
      "search": {
        "provider": "brave",
        "apiKey": "",
        "baseUrl": "",
        "maxResults": 5
      }
    },
    "exec": {
      "enable": true,
      "timeout": 60,
      "pathAppend": ""
    },
    "restrictToWorkspace": false,
    "mcpServers": {
      "lms": {
        "command": "uv",
        "args": ["run", "--directory", "/app/mcp", "python", "-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "",
          "NANOBOT_LMS_API_KEY": ""
        }
      }
    }
  }
}
